# Application
APP_ENV=local
LOG_LEVEL=INFO

# Local model serving
OLLAMA_BASE_URL=http://localhost:11434
MAIN_GENERATION_MODEL=qwen3:4b
QUALITY_GENERATION_MODEL=qwen2.5:7b-instruct
CRITIC_MODEL=deepseek-r1-distill-qwen:7b
MAIN_EMBEDDING_MODEL=nomic-embed-text-v1.5
CACHE_EMBEDDING_MODEL=bge-small-en-v1.5

# Local vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=askmydocs_documents
QDRANT_CACHE_COLLECTION=askmydocs_semantic_cache

# Configuration files
MODELS_CONFIG_PATH=configs/models.yaml
RETRIEVAL_CONFIG_PATH=configs/retrieval.yaml
PROMPTS_CONFIG_PATH=configs/prompts.yaml
EVALUATION_CONFIG_PATH=configs/evaluation.yaml
